<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  LRE Host Silent Installation / Upgrade - UserInput.xml
  ========================================================
  Used for: Controller, Data Processor, and full-Host Load Generators.
  NOT used for OneLG standalone - that uses direct command-line flags.

  This template is consumed by:
    02_Upgrade_Controller.ps1
    03_Upgrade_DataProcessor.ps1

  The script copies this file to a temp path, substitutes %%PLACEHOLDER%%
  tokens with real values, and passes it to:
      setup_host.exe /s LRASPCHOST=1 USER_CONFIG_FILE_PATH="<temp_path>"
-->
<PropertyList>

  <!-- -------------------------------------------------------- -->
  <!-- SYSTEM USER                                               -->
  <!-- -------------------------------------------------------- -->
  <Property Name="UseDefaultUserSetting">%%USE_DEFAULT_USER%%</Property>
  <Property Name="DomainName">%%DOMAIN_NAME%%</Property>
  <Property Name="SystemUserName">%%SYSTEM_USER_NAME%%</Property>
  <Property Name="SystemUserPwd">%%SYSTEM_USER_PWD%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- ENCRYPTION KEY  (must match LRE Server value)            -->
  <!-- -------------------------------------------------------- -->
  <Property Name="LW_CRYPTO_INIT_STRING">%%CRYPTO_KEY%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- PUBLIC KEY  (copied from LRE Server after server upgrade) -->
  <!-- -------------------------------------------------------- -->
  <Property Name="PublicKey">%%PUBLIC_KEY%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- NETWORK VIRTUALIZATION  (Y = install, N = skip)          -->
  <!-- -------------------------------------------------------- -->
  <Property Name="NVINSTALL">N</Property>

</PropertyList>
