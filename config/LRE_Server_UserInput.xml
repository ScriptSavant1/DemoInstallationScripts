<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  LRE Server Silent Installation / Upgrade - UserInput.xml
  =========================================================
  This file is a TEMPLATE. The upgrade script (01_Upgrade_LREServer.ps1)
  copies this file to a local temp path, substitutes all %%PLACEHOLDER%%
  tokens with real values from upgrade_config.ps1, and passes the result
  to the installer via:
      setup_server.exe /s USER_CONFIG_FILE_PATH="<temp_path>"

  DO NOT run the installer against this raw template.
  DO NOT commit passwords to source control - leave them as %%PLACEHOLDER%%
  and supply values in upgrade_config.ps1 (or enter at runtime prompt).
-->
<PropertyList>

  <!-- -------------------------------------------------------- -->
  <!-- SYSTEM USER                                               -->
  <!-- -------------------------------------------------------- -->
  <Property Name="UseDefaultUserSetting">%%USE_DEFAULT_USER%%</Property>
  <Property Name="DomainName">%%DOMAIN_NAME%%</Property>
  <Property Name="SystemUserName">%%SYSTEM_USER_NAME%%</Property>
  <Property Name="SystemUserPwd">%%SYSTEM_USER_PWD%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- ENCRYPTION KEY  (must match on every node)               -->
  <!-- -------------------------------------------------------- -->
  <Property Name="LW_CRYPTO_INIT_STRING">%%CRYPTO_KEY%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- REPOSITORY                                                -->
  <!-- -------------------------------------------------------- -->
  <Property Name="FileSystemRoot">%%FILE_SYSTEM_ROOT%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- DATABASE  (MS-SQL)                                        -->
  <!-- -------------------------------------------------------- -->
  <Property Name="DbType">MS-SQL</Property>
  <Property Name="DbServerHost">%%DB_SERVER_HOST%%</Property>
  <Property Name="DbServerPort">%%DB_SERVER_PORT%%</Property>
  <Property Name="DbAdminUser">%%DB_ADMIN_USER%%</Property>
  <Property Name="DbAdminPassword">%%DB_ADMIN_PASSWORD%%</Property>
  <Property Name="DbUsername">%%DB_USERNAME%%</Property>
  <Property Name="DbPassword">%%DB_PASSWORD%%</Property>
  <Property Name="LabDbName">%%LAB_DB_NAME%%</Property>
  <Property Name="AdminDbName">%%ADMIN_DB_NAME%%</Property>
  <Property Name="SiteDbName">%%SITE_DB_NAME%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- IIS                                                       -->
  <!-- -------------------------------------------------------- -->
  <Property Name="IIS_WEB_SITE_NAME">%%IIS_WEB_SITE_NAME%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- TLS / SSL                                                 -->
  <!-- -------------------------------------------------------- -->
  <Property Name="IisSecureConfiguration">%%IIS_SECURE_CONFIG%%</Property>
  <Property Name="IisSecureHostName">%%IIS_SECURE_HOST_NAME%%</Property>
  <Property Name="IisSecurePort">%%IIS_SECURE_PORT%%</Property>
  <Property Name="ImportCertificate">%%IMPORT_CERTIFICATE%%</Property>
  <Property Name="CertificateStore">%%CERTIFICATE_STORE%%</Property>
  <Property Name="CertificateName">%%CERTIFICATE_NAME%%</Property>
  <Property Name="CertificateFilePath">%%CERTIFICATE_FILE_PATH%%</Property>
  <Property Name="CertificatePassword">%%CERTIFICATE_PASSWORD%%</Property>

  <!-- -------------------------------------------------------- -->
  <!-- MAIL SERVER  (optional - set ConfigureMail to false      -->
  <!-- if not needed)                                           -->
  <!-- -------------------------------------------------------- -->
  <Property Name="ConfigureMail">false</Property>
  <Property Name="MailAddress"></Property>
  <Property Name="MailSmtp"></Property>
  <Property Name="MailPort">25</Property>
  <Property Name="MailEncryption">None</Property>
  <Property Name="MailAuthentication">false</Property>
  <Property Name="MailUserName"></Property>
  <Property Name="MailUserPassword"></Property>

  <!-- -------------------------------------------------------- -->
  <!-- NETWORK VIRTUALIZATION  (Y = install, N = skip)          -->
  <!-- -------------------------------------------------------- -->
  <Property Name="NVINSTALL">N</Property>

</PropertyList>
